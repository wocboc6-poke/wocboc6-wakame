<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ツールページ</title>
    <script src="/js/tailwindcss.js"></script>
    <link rel="stylesheet" href="/css/page.css">
    <style>
        /* 前回のページと同じCSSを適用 */
        .hero-section {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 50vh;
            background-color: #2d3748;
        }
        .searchbox {
            position: absolute;
            transform: translate(-50%, 0%);
            width: 80%;
            max-width: 700px;
            padding: 0.75rem;
            font-size: 1.2rem;
            border-radius: 25px;
            border: none;
            background-color: rgba(255, 255, 255, 0.1);
            color: white;
            outline: none;
            transition: all 0.3s ease;
        }
        .searchbox:focus {
            background-color: rgba(255, 255, 255, 0.3);
            box-shadow: 0 0 8px rgba(255, 255, 255, 0.5);
        }
        .app-card-container {
            display: flex;
            justify-content: center;
            gap: 16px;
            margin-top: 30px;
            flex-wrap: wrap;
        }
        .app-card {
            background-color: #1a202c;
            border-radius: 25px;
            padding: 15px;
            width: 180px;
            text-align: center;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border: 2px solid #4a5568;
            /* 要素を縦並びにして、リンクを一番下に押しやるための記述を追加 */
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
        .app-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 4px 10px rgba(255, 255, 255, 0.1);
        }
        .app-card img {
            width: 100%;
            height: auto;
            border-radius: 10px;
            margin-bottom: 10px;
        }
        .app-card h3 {
            color: white;
            font-size: 1.1rem;
            margin-bottom: 8px;
        }
        .app-card p {
            color: #cbd5e0;
            font-size: 0.875rem;
        }
        footer {
            background-color: #2d3748;
            color: #cbd5e0;
            padding: 1rem;
            text-align: center;
        }
    </style>
</head>
<body class="bg-gray-900 font-sans min-h-screen flex flex-col">

    <button class="back-button fixed top-5 left-5 z-50 bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2 px-4 rounded-lg shadow-lg transform transition-all duration-300 ease-in-out flex items-center space-x-2" onclick="window.location.href='/'">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        <span>戻る</span>
    </button>

    <div class="section flex-grow text-center pt-24 pb-10">
        
        <h1 class="text-4xl font-semibold mb-6 text-white">🧸ツール🧸</h1>
      
        <div class="mt-6 mb-10 px-4">
          <input type="text" id="search" placeholder="ツールを検索..." class="w-full max-w-md p-2 border rounded-lg shadow-md focus:outline-none focus:ring-2 focus:ring-blue-500 text-black">
        </div>

        <section class="py-10 px-4 bg-gray-800 rounded-t-3xl mx-2 shadow-lg h-full">

            <div class="app-card-container" id="app-list">
                <div class="app-card">
                    <div>
                        <h3 class="app-title">📱Android</h3>
                        <p class="app-description">くっそラグい仮想スマホで遊べます。</p>
                    </div>
                    <a href="/tools/tool/android" class="text-blue-400 hover:text-blue-300 hover:underline mt-4 inline-block text-sm">ツールを使用</a>
                </div>
                <div class="app-card">
                    <div>
                        <h3 class="app-title">小さい画面に<br>埋め込む</h3>
                        <p class="app-description">iPad用で、他者からの視認性を悪くします。</p>
                    </div>
                    <a href="/tools/tool/umekomi" class="text-blue-400 hover:text-blue-300 hover:underline mt-4 inline-block text-sm">ツールを使用</a>
                </div>
                <div class="app-card">
                    <div>
                        <h3 class="app-title">invAPI<br>チェッカー</h3>
                        <p class="app-description">入力されたinvidiousのURLを動くものと動かないものに分けられます。</p>
                    </div>
                    <a href="/tools/tool/inv" class="text-blue-400 hover:text-blue-300 hover:underline mt-4 inline-block text-sm">ツールを使用</a>
                </div>
                <div class="app-card">
                    <div>
                        <h3 class="app-title">htmlを取得</h3>
                        <p class="app-description">ウェブサイトのhtmlを取得して表示できます。</p>
                    </div>
                    <a href="/tools/tool/htmlget" class="text-blue-400 hover:text-blue-300 hover:underline mt-4 inline-block text-sm">ツールを使用</a>
                </div>
                <div class="app-card">
                    <div>
                        <h3 class="app-title">htmlproxy</h3>
                        <p class="app-description">htmlを取得する簡単なProxy。</p>
                    </div>
                    <a href="/tools/tool/get" class="text-blue-400 hover:text-blue-300 hover:underline mt-4 inline-block text-sm">ツールを使用</a>
                </div>
            </div>
        </section>
    </div>

    <footer class="mt-auto">
        <p>(・∀・)</p>
    </footer>

    <script>
        const searchInput = document.getElementById('search');
        // クラス名を前のページと合わせたため、JSも .app-card を取得するように修正
        const tools = document.querySelectorAll('.app-card');

        searchInput.addEventListener('input', function() {
            const searchText = searchInput.value.toLowerCase();

            tools.forEach(tool => {
                const title = tool.querySelector('.app-title').textContent.toLowerCase();
                const description = tool.querySelector('.app-description').textContent.toLowerCase();
                if (title.includes(searchText) || description.includes(searchText)) {
                    tool.style.display = ''; // CSSのFlexboxを維持したい場合は 'flex' を指定しても良いですが、空文字で元のdisplayに戻ります
                } else {
                    tool.style.display = 'none';
                }
            });
        });
    </script>

</body>
</html>
