<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>わかめtube - 急上昇</title>

  <meta name="description" content="まっしろになってゆく">
  <meta property="og:title" content="わかめtube">
  <meta property="og:description" content="まっしろになってゆく">
  <meta property="og:site_name" content="わかめtube | まっしろになっていく">
  <meta property="og:image" content="https://cdn.glitch.global/5b8b419f-e61e-4533-9e15-5b2805b88d0e/IMG_1111_Original.jpeg">
  <meta name="theme-color" content="#1F2937">
  <link rel="icon" href="https://cdn.glitch.global/5b8b419f-e61e-4533-9e15-5b2805b88d0e/IMG_1111_Original.jpeg">

  <script src="https://cdn.tailwindcss.com"></script>

  <link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
  <script src="https://code.jquery.com/jquery-3.5.1.js"></script>
  <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.js"></script>

  <style>
    .ui-autocomplete { z-index: 1000 !important; }
    body { background-color: #111827; } 
    /* タブのスタイル調整 */
    .tab-btn { transition: all 0.2s; cursor: pointer; }
  </style>
</head>

<body class="bg-gray-900 text-white font-sans antialiased">

  <header class="bg-gray-800 p-4 flex justify-between items-center fixed top-0 left-0 w-full z-50 shadow-md">
      <form action="/wkt/s" method="get" class="w-full md:w-1/2 relative flex items-center" id="searchForm">
          <input type="text" name="q" id="searchbox" placeholder="検索" 
                 class="w-full p-2 pr-10 rounded bg-gray-700 text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-white border-none transition-shadow">
          <button type="button" id="clearBtn" class="absolute right-2 top-1/2 -translate-y-1/2 flex items-center justify-center h-6 w-6 rounded-full hover:bg-gray-600 text-gray-300 text-lg leading-none hidden">
            ×
          </button>
      </form>

      <nav class="hidden md:flex space-x-6 ml-4">
          <a href="/wkt" class="text-gray-300 hover:text-white transition font-medium">ホーム</a>
          <a href="/wkt/cl/history" class="text-gray-300 hover:text-white transition font-medium">再生履歴</a>
          <a href="/wkt/cl/shistory" class="text-gray-300 hover:text-white transition font-medium">検索履歴</a>
      </nav>
      
      <div class="md:hidden ml-2">
        <a href="/wkt" class="text-gray-300 hover:text-white text-sm font-medium">ホーム</a>
      </div>
  </header>
  
  <div class="container mx-auto p-4 pt-24"> 
      <div class="flex space-x-6 mb-6 border-b border-gray-700 text-lg" id="tabs">
          <button id="tab-trend" class="tab-btn pb-2 text-white font-bold border-b-2 border-blue-500">急上昇</button>
          <button id="tab-gaming" class="tab-btn pb-2 text-gray-400 font-bold hover:text-white hidden">ゲーム</button>
          <button id="tab-music" class="tab-btn pb-2 text-gray-400 font-bold hover:text-white hidden">音楽</button>
          <button id="tab-live" class="tab-btn pb-2 text-gray-400 font-bold hover:text-white hidden">ライブ</button>
      </div>

      <div id="trend-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12"></div>
      <div id="gaming-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12 hidden"></div>
      <div id="music-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12 hidden"></div>
      <div id="live-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12 hidden"></div>
  </div>

  <script>
  /* -----------------------------------------------
     1. UI制御: 検索ボックスのクリアボタン
  ----------------------------------------------- */
  const searchBox = document.getElementById('searchbox');
  const clearBtn = document.getElementById('clearBtn');

  function toggleClearButton() {
      clearBtn.style.display = searchBox.value ? 'block' : 'none';
  }

  searchBox.addEventListener('input', toggleClearButton);
  clearBtn.addEventListener('click', () => {
      searchBox.value = '';
      searchBox.focus();
      toggleClearButton();
  });
  toggleClearButton();

  /* -----------------------------------------------
     2. データ描画: トレンド動画とタブの制御
  ----------------------------------------------- */
  document.addEventListener("DOMContentLoaded", () => {
      
      // EJS変数の展開
      const base64Data = <%- JSON.stringify(typeof topVideos_base64 !== 'undefined' ? topVideos_base64 : null) %>;
      const siaData = <%- JSON.stringify(typeof topVideos_sia !== 'undefined' ? topVideos_sia : null) %>;
      const invData = <%- JSON.stringify(typeof topVideos_inv !== 'undefined' ? topVideos_inv : null) %>;

      // 要素の取得
      const trendContainer = document.getElementById("trend-container");
      const gamingContainer = document.getElementById("gaming-container");
      const musicContainer = document.getElementById("music-container");
      const liveContainer = document.getElementById("live-container");

      const tabTrend = document.getElementById("tab-trend");
      const tabGaming = document.getElementById("tab-gaming");
      const tabMusic = document.getElementById("tab-music");
      const tabLive = document.getElementById("tab-live");

      let sourceTrend = "none";
      let trendingList = [];

      // ① 急上昇(Trending)、ゲーム、音楽のデータ割り当て
      if (base64Data && base64Data.trending && base64Data.trending.length > 0) {
          sourceTrend = "base64";
          trendingList = base64Data.trending;
          
          // ゲームと音楽のタブ・データ準備
          if (base64Data.gaming && base64Data.gaming.length > 0) {
              tabGaming.classList.remove("hidden");
              renderVideos(base64Data.gaming, gamingContainer, "base64");
          }
          if (base64Data.music && base64Data.music.length > 0) {
              tabMusic.classList.remove("hidden");
              renderVideos(base64Data.music, musicContainer, "base64");
          }
      } else if (siaData && siaData.trending && siaData.trending.length > 0) {
          sourceTrend = "sia";
          trendingList = siaData.trending;
      }
      
      // 急上昇を描画
      renderVideos(trendingList, trendContainer, sourceTrend);

      // ② ライブのデータ割り当て (Invidious)
      if (invData && invData.length > 0) {
          tabLive.classList.remove("hidden");
          renderVideos(invData, liveContainer, "inv");
      }

      /* =========================================
         タブ切り替えロジック
      ========================================= */
      const tabs = [
          { btn: tabTrend, container: trendContainer, activeColor: "border-blue-500" },
          { btn: tabGaming, container: gamingContainer, activeColor: "border-green-500" },
          { btn: tabMusic, container: musicContainer, activeColor: "border-red-500" },
          { btn: tabLive, container: liveContainer, activeColor: "border-yellow-500" }
      ];

      function switchTab(selectedBtn) {
          tabs.forEach(tab => {
              if (tab.btn === selectedBtn) {
                  tab.btn.classList.add("text-white", "border-b-2", tab.activeColor);
                  tab.btn.classList.remove("text-gray-400");
                  tab.container.classList.remove("hidden");
              } else {
                  tab.btn.classList.remove("text-white", "border-b-2", tab.activeColor);
                  tab.btn.classList.add("text-gray-400");
                  tab.container.classList.add("hidden");
              }
          });
      }

      tabTrend.addEventListener("click", () => switchTab(tabTrend));
      tabGaming.addEventListener("click", () => switchTab(tabGaming));
      tabMusic.addEventListener("click", () => switchTab(tabMusic));
      tabLive.addEventListener("click", () => switchTab(tabLive));


      /* =========================================
         描画・フォーマット関数群
      ========================================= */
      function timeAgo(publishedAt) {
          if (!publishedAt) return "";
          if (typeof publishedAt === 'string' && publishedAt.includes('ago')) return publishedAt;

          const now = new Date();
          const published = new Date(publishedAt);
          if (isNaN(published.getTime())) return publishedAt;

          const diffMs = now - published;
          const diffMin = Math.floor(diffMs / 60000);
          const diffHr = Math.floor(diffMin / 60);
          const diffDay = Math.floor(diffHr / 24);

          if (diffMin < 60) return `${diffMin}分前`;
          if (diffHr < 24) return `${diffHr}時間前`;
          return `${diffDay}日前`;
      }

      function parseDuration(duration) {
          if (!duration) return "";
          
          if (typeof duration === "number" || /^\d+$/.test(duration)) {
              const totalSeconds = parseInt(duration, 10);
              if (totalSeconds === 0) return "LIVE";
              
              const h = Math.floor(totalSeconds / 3600);
              const m = Math.floor((totalSeconds % 3600) / 60);
              const s = totalSeconds % 60;
              if (h > 0) return `${h}:${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
              return `${m}:${s.toString().padStart(2, '0')}`;
          }

          const match = duration.match(/PT(?:(\d+)H)?(?:(\d+)M)?(?:(\d+)S)?/);
          if (!match) return "";
          
          const hours = (match[1] || '').replace('H', '');
          const minutes = (match[2] || '').replace('M', '');
          const seconds = (match[3] || '').replace('S', '');

          if (hours) return `${hours}:${minutes.padStart(2, '0')}:${seconds.padStart(2, '0')}`;
          return `${minutes || '0'}:${seconds.padStart(2, '0')}`;
      }

      function renderVideos(videos, containerElement, source) {
          containerElement.innerHTML = "";
          if (!videos || videos.length === 0) return;

          videos.forEach(item => {
              let id, title, channel, channelId, publishedAt, durationText, viewCount, channelIcon, thumbnailUrl;

              if (source === "base64") {
                  id = item.id;
                  title = item.title;
                  channel = item.channel;
                  channelId = item.channelId;
                  publishedAt = timeAgo(item.publishedAt);
                  durationText = parseDuration(item.duration);
                  viewCount = Number(item.viewCount).toLocaleString();
                  channelIcon = item.channelIcon || "";
                  thumbnailUrl = (item.thumbnails && item.thumbnails.standard && item.thumbnails.standard.url) 
                                  ? item.thumbnails.standard.url 
                                  : `/wkt/back/vi/${id}/mqdefault.jpg`;
              } 
              else if (source === "sia") {
                  id = item.id;
                  title = item.title;
                  channel = item.channel;
                  channelId = item.channelId;
                  publishedAt = timeAgo(item.publishedAt);
                  durationText = parseDuration(item.duration);
                  viewCount = Number(item.viewCount).toLocaleString();
                  channelIcon = item.channelIcon || "";
                  thumbnailUrl = `/wkt/back/vi/${id}/mqdefault.jpg`;
              } 
              else if (source === "inv") {
                  id = item.videoId;
                  title = item.title;
                  channel = item.author;
                  channelId = item.authorId;
                  publishedAt = item.publishedText || timeAgo(item.published * 1000); 
                  durationText = parseDuration(item.lengthSeconds);
                  viewCount = item.viewCount ? Number(item.viewCount).toLocaleString() : "";
                  channelIcon = (item.authorThumbnails && item.authorThumbnails.length > 0) ? item.authorThumbnails[0].url : "";
                  thumbnailUrl = `/wkt/back/vi/${id}/mqdefault.jpg`;
              }

              const channelUrl = channelId ? `/wkt/c/${channelId}` : '#';

              // ライブかどうかでバッジのスタイルとテキストを分ける
              const isLive = durationText === "LIVE";
              const badgeClass = isLive ? "bg-red-600 bg-opacity-90" : "bg-black bg-opacity-80";
              const badgeText = isLive ? "ライブ" : durationText;

              const html = `
                <div class="result-item bg-gray-800 p-4 rounded-lg shadow hover:bg-gray-700 transition duration-200">
                    <a href="/wkt/watch/${id}" class="block relative group">
                        <img loading="lazy" src="${thumbnailUrl}" alt="${title}" class="w-full h-auto rounded aspect-video object-cover">
                        
                        <span class="absolute bottom-1 right-1 ${badgeClass} text-white text-xs px-1.5 py-0.5 rounded font-medium">
                            ${badgeText}
                        </span>

                        <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-10 transition rounded"></div>
                    </a>

                    <div class="mt-3 flex items-start space-x-3">
                        <a href="${channelUrl}" class="flex-shrink-0">
                            <img src="${channelIcon}" alt="${channel}" class="w-9 h-9 rounded-full object-cover bg-gray-600 border border-gray-700">
                        </a>
                        
                        <div class="flex-1 min-w-0">
                            <a href="/wkt/watch/${id}">
                                <p class="text-white font-bold text-sm leading-snug line-clamp-2 mb-1 group-hover:text-blue-400 transition">
                                    ${title}
                                </p>
                            </a>
                            
                            <a href="${channelUrl}" class="text-gray-400 text-xs hover:text-white transition mb-0.5 block truncate">
                                ${channel}
                            </a>
                            
                            <p class="text-gray-500 text-xs">
                               ${viewCount} 回視聴 • ${publishedAt}
                            </p>
                        </div>
                    </div>
                </div>
              `;
              containerElement.innerHTML += html;
          });
      }
  });

  /* -----------------------------------------------
     3. 機能維持: jQuery Autocomplete (サジェスト)
  ----------------------------------------------- */
  $(function () {
      $('#searchbox').autocomplete({
          source: function (request, response) {
              $.ajax({
                  url: '/wkt/back/suggest',
                  data: { keyword: request.term },
                  success: function (data) {
                      response(data);
                  }
              });
          },
          delay: 200,
          select: function (event, ui) {
              $('#searchbox').val(ui.item.value);
              $('#searchForm').submit();
          }
      });
  });
  </script>

</body>
</html>
